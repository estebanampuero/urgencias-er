# =====================================================================
# Variables de entorno · Sistema de Entrega de Turno
# Copiar como .env y editar valores. NO commitear .env real.
# En EasyPanel: setear estas variables en la sección Environment del servicio.
# =====================================================================

# OBLIGATORIA en producción. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-por-token-aleatorio-de-64-chars

# Puerto interno del contenedor (EasyPanel hace el mapping HTTP)
PORT=5050

# Workers/threads de waitress (ajustar según CPU del VPS)
THREADS=8

# === LLM (opcional pero recomendado) ===
# Generar en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_MODEL=claude-haiku-4-5-20251001

# === Backup ===
# Cantidad de copias de backup que se mantienen (rotación)
BACKUP_KEEP=30

# === Sembrar datos demo al primer arranque ===
# Setear "true" SOLO la primera vez. Después dejar vacío o "false"
# para que NO sobrescriba la BD en cada redeploy.
SEED_DEMO=true

# === Pre-cargar modelo Whisper al arrancar (evita ~30s en primer request) ===
PRELOAD_STT=false

# === Logging ===
# JSON estructurado por default (compatible con logs de EasyPanel).
# Cambiar a false para logs human-readable.
LOG_JSON=true
LOG_LEVEL=INFO

# === Rate limiting storage ===
# memory:// para single-replica. Para multi-replica usar redis://host:port
LIMITER_STORAGE=memory://
